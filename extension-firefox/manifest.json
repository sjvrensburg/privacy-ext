{
  "manifest_version": 3,
  "name": "PII Redactor (local daemon client)",
  "version": "0.4.0",
  "description": "Detects and redacts PII pasted into web forms via a local on-device model daemon.",
  "browser_specific_settings": {
    "gecko": {
      "id": "pii-redactor@semplifica.ai",
      "strict_min_version": "115.0",
      "data_collection_permissions": { "required": ["none"] }
    }
  },
  "permissions": ["storage", "nativeMessaging", "activeTab"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "background": { "scripts": ["ai-sites.js", "background.js"] },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PII Redactor",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
